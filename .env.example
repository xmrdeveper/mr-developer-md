# Environment example for mr-developer-md WhatsApp ↔ Telegram bot (Railway-ready)

# REQUIRED
# Your Telegram Bot API token (get from @BotFather)
TELEGRAM_TOKEN=

# Optional but recommended
# When true, owner/admin commands become available to everyone (USE WITH CAUTION)
PUBLIC_MODE=false

# Optional: passphrase used to encrypt session files at rest (Fernet). Keep this secret.
# WARNING: changing this will make existing encrypted sessions unreadable
PASS_PHRASE=

# Directory where session & pairing state is stored inside the container
# For Railway, set this to the mount path of a persistent volume (e.g. /data/auth_states)
DATA_DIR=/data/auth_states

# Optional: comma-separated list of Telegram user IDs granted owner privileges
OWNER_IDS=

# Dangerous operations (eval, terminal) require explicit opt-in. Default: disabled
ALLOW_DANGEROUS=false

# Other useful settings
# LOG_LEVEL=info
# TIMEZONE=UTC
