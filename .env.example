# Environment example for mr-developer-md WhatsApp ↔ Telegram bot

# Telegram bot token
TELEGRAM_TOKEN=

# Optional: directory to store per-user auth/session state
DATA_DIR=./auth_states

# Optional: passphrase used to encrypt session files (if set, storage will be encrypted)
# WARNING: changing this will make existing encrypted sessions unreadable
PASS_PHRASE=

# Optional: comma-separated list of Telegram user IDs allowed to use admin/owner commands
OWNER_IDS=
